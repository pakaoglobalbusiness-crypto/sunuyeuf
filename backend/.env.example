# Copier vers .env et remplir pour la production

# Obligatoire en production
JWT_SECRET=changez-moi-64-caracteres-aleatoires
NODE_ENV=development
PORT=3000

# Origines autorisées (CORS), séparées par des virgules
# CORS_ORIGINS=https://admin.gologui.sn,https://gologui.sn

# Paiements : mock (dev) | paydunya
PAYMENT_PROVIDER=mock
# PAYDUNYA_MASTER_KEY=
# PAYDUNYA_PRIVATE_KEY=
# PAYDUNYA_TOKEN=
# PAYDUNYA_MODE=test            # test | live
# PAYMENT_CALLBACK_URL=https://gologui-api.onrender.com/api/v1/payments/webhook/paydunya

# SMS : mock (dev, code affiché dans la réponse) | orange | twilio
SMS_PROVIDER=mock
# ORANGE_SMS_CLIENT_ID=
# ORANGE_SMS_CLIENT_SECRET=
# ORANGE_SMS_SENDER=+221XXXXXXXXX
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
